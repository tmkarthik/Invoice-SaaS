<!-- SCREEN 4: HISTORY -->
<!-- ======================= -->
<div class="screen" id="s4">
  <div class="topbar">
    <div class="tb-left">
      <div class="logomark"><svg viewBox="0 0 16 16"><path d="M3 3h4v4H3zm6 0h4v4h-4zM3 9h4v4H3zm6 0h4v4h-4z"/></svg></div>
      <span class="brand">InvoiceCraft</span>
    </div>
    <div class="tb-right">
      <button class="btn" onclick="go(1)">
        <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" width="12" height="12"><line x1="7" y1="2" x2="2" y2="6"/><line x1="2" y1="6" x2="7" y2="10"/><line x1="2" y1="6" x2="11" y2="6"/></svg>
        Back to Editor
      </button>
    </div>
  </div>
  <div class="vh-body">
    <div class="vh-dimmed">
      <div class="vh-fake-canvas">
        <div class="vhf-line acc"></div><div class="vhf-line" style="width:55%"></div><div class="vhf-line" style="width:40%"></div>
        <div class="vhf-block"></div>
        <div class="vhf-line" style="width:90%;margin-top:12px"></div><div class="vhf-line" style="width:75%"></div><div class="vhf-line" style="width:82%"></div>
      </div>
    </div>
    <div class="vh-panel">
      <div class="vh-head">
        <span class="vh-title">Version history</span>
        <button class="vh-close" onclick="go(1)">
          <svg viewBox="0 0 11 11" fill="none" stroke="currentColor" stroke-width="1.4"><line x1="2" y1="2" x2="9" y2="9"/><line x1="9" y1="2" x2="2" y2="9"/></svg>
        </button>
      </div>
      <div class="vh-list">
        <!-- Manual population for visual structure -->
        <div class="vhi cur">
            <div class="vhi-top">
              <span class="vhi-name">Version 5</span>
