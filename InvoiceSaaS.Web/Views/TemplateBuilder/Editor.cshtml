            <div class="vhi-changes">Updated totals layout, added discount row, adjusted header font</div>
            <div class="vhi-actions">
              <button class="vha-btn restore">Restore</button>
              <button class="vha-btn">Duplicate</button>
            </div>
        </div>
        <div class="vhi">
            <div class="vhi-top">
              <span class="vhi-name">Version 4</span>
            </div>
            <div class="vhi-date">Today, 11:12 AM</div>
            <div class="vhi-changes">Moved bank details below totals, updated logo size to 90px</div>
            <div class="vhi-actions">
              <button class="vha-btn restore">Restore</button>
              <button class="vha-btn">Duplicate</button>
            </div>
        </div>
      </div>
    </div>
  </div>
</div>
