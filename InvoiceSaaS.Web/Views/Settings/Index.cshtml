@using InvoiceSaaS.Application.DTOs
@using InvoiceSaaS.Web.Models
@model SettingsViewModel
@{
    ViewData["Title"] = "Settings";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="h3 mb-0 text-gray-800">Account Settings</h1>
            <p class="text-muted">Manage your invoicing defaults, branding, and tax configurations.</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Tabs Navigation -->
    <ul class="nav nav-tabs mb-4" id="settingsTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="general-tab" data-bs-toggle="tab" data-bs-target="#general" type="button" role="tab">General & Branding</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="taxes-tab" data-bs-toggle="tab" data-bs-target="#taxes" type="button" role="tab">Taxes</button>
        </li>
    </ul>

    <div class="tab-content" id="settingsTabsContent">
        <!-- General Settings Tab -->
        <div class="tab-pane fade show active" id="general" role="tabpanel">
            <div class="row">
                <div class="col-lg-8">
                    <form asp-action="Update" method="post" class="card shadow mb-4">
                        <div class="card-header py-3">
                            <h6 class="m-0 font-weight-bold text-primary">Invoicing Defaults</h6>
                        </div>
                        <div class="card-body">
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label font-weight-bold">Invoice Prefix</label>
                                    <input name="Prefix" value="@Model.InvoiceSettings.Prefix" class="form-control" placeholder="e.g. INV-" />
                                    <small class="text-muted">Appears before the number.</small>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label font-weight-bold">Invoice Suffix</label>
                                    <input name="Suffix" value="@Model.InvoiceSettings.Suffix" class="form-control" placeholder="e.g. -2024" />
                                    <small class="text-muted">Appears after the number.</small>
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label font-weight-bold">Next Invoice Number</label>
                                    <input type="number" name="NextInvoiceNumber" value="@Model.InvoiceSettings.NextInvoiceNumber" class="form-control" min="1" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label font-weight-bold">Default Due Days</label>
                                    <input type="number" name="DefaultDueDays" value="@Model.InvoiceSettings.DefaultDueDays" class="form-control" min="0" />
                                </div>
                            </div>
                            <hr />
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label font-weight-bold">Default Currency</label>
                                    <select name="DefaultCurrency" class="form-select">
                                        <option value="USD" selected="@(Model.InvoiceSettings.DefaultCurrency == "USD")">USD ($)</option>
                                        <option value="EUR" selected="@(Model.InvoiceSettings.DefaultCurrency == "EUR")">EUR (€)</option>
                                        <option value="GBP" selected="@(Model.InvoiceSettings.DefaultCurrency == "GBP")">GBP (£)</option>
                                        <option value="INR" selected="@(Model.InvoiceSettings.DefaultCurrency == "INR")">INR (₹)</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label font-weight-bold">Base Tax Rate (%)</label>
                                    <div class="input-group">
                                        <input type="number" step="0.01" name="DefaultTaxRate" value="@Model.InvoiceSettings.DefaultTaxRate" class="form-control" />
                                        <span class="input-group-text">%</span>
                                    </div>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label font-weight-bold">Logo URL</label>
                                <input name="LogoUrl" value="@Model.InvoiceSettings.LogoUrl" class="form-control" placeholder="https://your-site.com/logo.png" />
                            </div>
                        </div>
                        <div class="card-footer text-end">
                            <button type="submit" class="btn btn-primary px-4">Save Changes</button>
                        </div>
                    </form>
                </div>
                <div class="col-lg-4">
                    <div class="card shadow mb-4">
                        <div class="card-header py-3">
                            <h6 class="m-0 font-weight-bold text-primary">Numbering Preview</h6>
                        </div>
                        <div class="card-body text-center bg-light p-4">
                            <div class="h4 font-weight-bold">
                                <span id="previewPrefix">@Model.InvoiceSettings.Prefix</span><span id="previewNumber">@Model.InvoiceSettings.NextInvoiceNumber</span><span id="previewSuffix">@Model.InvoiceSettings.Suffix</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Taxes Tab -->
        <div class="tab-pane fade" id="taxes" role="tabpanel">
            <div class="row">
                <div class="col-lg-8">
                    <div class="card shadow mb-4">
                        <div class="card-header py-3 d-flex justify-content-between align-items-center">
                            <h6 class="m-0 font-weight-bold text-primary">Tax Definitions</h6>
                            <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addTaxModal">
                                <i class="fas fa-plus"></i> Add New Tax
                            </button>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <thead class="bg-light">
                                        <tr>
                                            <th>Name</th>
                                            <th>Rate</th>
                                            <th>Type</th>
                                            <th>Priority</th>
                                            <th class="text-end">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var tax in Model.Taxes)
                                        {
                                            <tr>
                                                <td><span class="fw-bold">@tax.Name</span></td>
                                                <td>@(tax.Rate * 100)%</td>
                                                <td>
                                                    @if (tax.IsCompound)
                                                    {
                                                        <span class="badge bg-warning text-dark">Compound</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-info">Flat</span>
                                                    }
                                                </td>
                                                <td>@tax.Priority</td>
                                                <td class="text-end">
                                                    <form asp-action="DeleteTax" asp-route-id="@tax.Id" method="post" onsubmit="return confirm('Remove this tax definition?');">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4"><path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
                                                        </button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                        @if (!Model.Taxes.Any())
                                        {
                                            <tr>
                                                <td colspan="5" class="text-center py-4 text-muted small">
                                                    No additional taxes defined. Use additional taxes for GST, VAT, or specific regional duties.
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="card bg-info text-white shadow">
                        <div class="card-body small">
                            <h6 class="font-weight-bold">Understanding Taxes</h6>
                            <p><strong>Flat Tax:</strong> Calculated on the base subtotal.</p>
                            <p class="mb-0"><strong>Compound Tax:</strong> Calculated on (Subtotal + Previous Taxes). These are processed in order of Priority.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Tax Modal -->
<div class="modal fade" id="addTaxModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="CreateTax" method="post" class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">New Tax Definition</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Tax Name</label>
                    <input name="Name" class="form-control" required placeholder="e.g. VAT, GST" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Rate (Decimal, e.g. 0.18 for 18%)</label>
                    <input type="number" step="0.0001" name="Rate" class="form-control" required value="0.05" />
                </div>
                <div class="mb-3 d-flex align-items-center">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="IsCompound" value="true">
                        <label class="form-check-label ps-2">Compound Tax?</label>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Priority (Application Order)</label>
                    <input type="number" name="Priority" class="form-control" value="0" />
                    <small class="text-muted">Lower numbers are applied first.</small>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Create Tax</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const prefixInput = document.querySelector('input[name="Prefix"]');
        const suffixInput = document.querySelector('input[name="Suffix"]');
        const numberInput = document.querySelector('input[name="NextInvoiceNumber"]');
        const previewPrefix = document.getElementById('previewPrefix');
        const previewSuffix = document.getElementById('previewSuffix');
        const previewNumber = document.getElementById('previewNumber');

        const updatePreview = () => {
            previewPrefix.textContent = prefixInput.value;
            previewSuffix.textContent = suffixInput.value;
            previewNumber.textContent = numberInput.value;
        };

        prefixInput?.addEventListener('input', updatePreview);
        suffixInput?.addEventListener('input', updatePreview);
        numberInput?.addEventListener('input', updatePreview);
    </script>
}
