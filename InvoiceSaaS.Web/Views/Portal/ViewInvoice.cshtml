@model InvoiceSaaS.Application.DTOs.InvoiceDto
@{
    Layout = "_PortalLayout";
    ViewData["Title"] = $"Invoice {Model.Number}";
}

<div class="max-w-4xl mx-auto py-8">
    <div class="mb-6 flex justify-between items-center">
        <a asp-action="Index" asp-route-customerId="@Model.CustomerId" class="flex items-center text-sm text-indigo-600 font-medium hover:text-indigo-900">
            <svg viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4 mr-1"><path d="M10 12.796V3.204L4.519 8 10 12.796zm-.659.724l-5.481-4.796a1 1 0 010-1.448l5.481-4.796A1 1 0 0111 3.204v9.592a1 1 0 01-1.659.724z"/></svg>
            Back to All Invoices
        </a>
        <div class="flex gap-4">
            <a asp-action="Download" asp-route-id="@Model.Id" class="px-4 py-2 bg-white border border-gray-300 text-sm font-medium text-gray-700 rounded-md hover:bg-gray-50 flex items-center">
                <svg viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4 mr-2"><path d="M.5 9.9a.5.5 0 01.5.5v2.5a1 1 0 001 1h12a1 1 0 001-1v-2.5a.5.5 0 011 0v2.5a2 2 0 01-2 2H2a2 2 0 01-2-2v-2.5a.5.5 0 01.5-.5z"/><path d="M7.646 11.854a.5.5 0 00.708 0l3-3a.5.5 0 00-.708-.708L8.5 10.293V1.5a.5.5 0 00-1 0v8.793L5.354 8.146a.5.5 0 10-.708.708l3 3z"/></svg>
                Download PDF
            </a>
            @if (Model.Status.ToString() != "Paid")
            {
                <form asp-action="Pay" asp-route-id="@Model.Id" method="post">
                    <button type="submit" class="px-6 py-2 bg-indigo-600 text-sm font-medium text-white rounded-md hover:bg-indigo-700 shadow-md transition-all flex items-center">
                         <svg viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4 mr-2"><path d="M0 4a2 2 0 012-2h12a2 2 0 012 2v8a2 2 0 01-2 2H2a2 2 0 01-2-2V4zm2-1a1 1 0 00-1 1v1h14V4a1 1 0 00-1-1H2zm13 4H1v5a1 1 0 001 1h12a1 1 0 001-1V7z"/><path d="M2 10a1 1 0 011-1h1a1 1 0 011 1v1a1 1 0 01-1 1H3a1 1 0 01-1-1v-1z"/></svg>
                         Pay Now (@Model.Amount.ToString("C") @Model.Currency)
                    </button>
                </form>
            }
        </div>
    </div>

    <!-- The actual invoice preview -->
    <div class="bg-white shadow-xl rounded-lg overflow-hidden border border-gray-200">
        <div class="p-12">
            <div class="flex justify-between mb-12">
                <div>
                    <div class="text-3xl font-extrabold text-indigo-600 tracking-tight">INVOICE</div>
                    <div class="text-sm text-gray-500 mt-1">Ref: #@Model.Number</div>
                </div>
                <div class="text-right">
                    <div class="text-sm text-gray-500">Amount Due</div>
                    <div class="text-2xl font-bold text-gray-900">@Model.Amount.ToString("C") @Model.Currency</div>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-12 mb-12 border-t border-gray-100 pt-8">
                <div>
                   <div class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-3 text-indigo-500">Bill To</div>
                   <div class="text-lg font-bold text-gray-900">@Model.Customer?.Name</div>
                   <div class="text-sm text-gray-600">@Model.Customer?.BillingAddress</div>
                </div>
                <div>
                   <div class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-3 text-indigo-500">Due Date</div>
                   <div class="text-lg font-bold text-gray-900 mb-1">@Model.DueDateUtc.ToLongDateString()</div>
                   <div class="text-sm text-gray-500">Issued On @Model.IssueDateUtc.ToLongDateString()</div>
                </div>
            </div>

            <table class="w-full mb-12">
                <thead>
                    <tr class="text-left border-b border-gray-200 text-xs font-bold text-gray-500 uppercase tracking-wider">
                        <th class="py-3">Description</th>
                        <th class="py-3 text-center">Qty</th>
                        <th class="py-3 text-right">Unit Price</th>
                        <th class="py-3 text-right">Total</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var item in Model.InvoiceItems)
                    {
                        <tr>
                            <td class="py-4 text-sm font-medium text-gray-900">@item.Description</td>
                            <td class="py-4 text-center text-sm text-gray-600">@item.Quantity</td>
                            <td class="py-4 text-right text-sm text-gray-600">@item.UnitPrice.ToString("C")</td>
                            <td class="py-4 text-right text-sm font-bold text-gray-900">@item.Total.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="flex justify-end pt-8 border-t border-gray-200">
                <div class="w-64 space-y-3">
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-500">Subtotal</span>
                        <span class="text-gray-900">@Model.Subtotal.ToString("C")</span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-500">Tax (@((Model.TaxRate * 100).ToString("N1"))%)</span>
                        <span class="text-gray-900">@Model.TaxTotal.ToString("C")</span>
                    </div>
                    <div class="flex justify-between pt-3 border-t border-indigo-100">
                        <span class="text-base font-bold text-gray-900">Grand Total</span>
                        <span class="text-lg font-bold text-indigo-600">@Model.Amount.ToString("C") @Model.Currency</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
